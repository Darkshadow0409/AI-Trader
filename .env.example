AI_TRADER_ENV=development
AI_TRADER_HOST=127.0.0.1
AI_TRADER_PORT=8000
AI_TRADER_FRONTEND_PORT=5173
AI_TRADER_USE_SAMPLE_ONLY=true
AI_TRADER_SQLITE_PATH=data/sqlite/ai_trader.db
AI_TRADER_DUCKDB_PATH=data/sqlite/ai_trader.duckdb
AI_TRADER_PARQUET_DIR=data/parquet
AI_TRADER_DEFAULT_TIMEFRAME=1d
AI_TRADER_API_REFRESH_SECONDS=900
AI_TRADER_FRED_API_KEY=
AI_TRADER_OPENAI_API_KEY=
AI_TRADER_OLLAMA_URL=http://127.0.0.1:11434
AI_TRADER_ALERT_ENABLE_IN_APP=true
AI_TRADER_ALERT_ENABLE_TELEGRAM=false
AI_TRADER_ALERT_ENABLE_DISCORD=false
AI_TRADER_ALERT_IN_APP_MIN_SEVERITY=info
AI_TRADER_ALERT_TELEGRAM_MIN_SEVERITY=warning
AI_TRADER_ALERT_DISCORD_MIN_SEVERITY=info
AI_TRADER_ALERT_DEDUPE_WINDOW_MINUTES=240
AI_TRADER_ALERT_COOLDOWN_MINUTES=60
AI_TRADER_TELEGRAM_BOT_TOKEN=
AI_TRADER_TELEGRAM_CHAT_ID=
AI_TRADER_DISCORD_WEBHOOK_URL=
