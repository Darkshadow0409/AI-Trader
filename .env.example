#
# AI Trader shared env template.
# Local development can copy this file to `.env`.
# Production-staging can copy this file to `.env.production` and then replace the placeholder values.
#

# Core runtime
AI_TRADER_ENV=development
AI_TRADER_HOST=127.0.0.1
AI_TRADER_PORT=8000
AI_TRADER_FRONTEND_PORT=5173
AI_TRADER_ENABLE_SCHEDULER=true
AI_TRADER_USE_SAMPLE_ONLY=false
AI_TRADER_DEFAULT_TIMEFRAME=1d
AI_TRADER_API_REFRESH_SECONDS=900
AI_TRADER_PIPELINE_REFRESH_MINUTES=15
AI_TRADER_FIXTURE_NOW_ISO=2026-03-15T11:30:00+00:00
AI_TRADER_PAPER_ACCOUNT_SIZE=10000

# Storage
AI_TRADER_SQLITE_PATH=data/sqlite/ai_trader.db
AI_TRADER_DUCKDB_PATH=data/sqlite/ai_trader.duckdb
AI_TRADER_PARQUET_DIR=data/parquet
AI_TRADER_DIAGNOSTICS_DIR=data/diagnostics

# Market data and broker-style mapping
AI_TRADER_BROKER_MARKET_DATA_ENABLED=false
AI_TRADER_SYMBOL_MAPPING_JSON=
AI_TRADER_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","https://aitrader.sajaljain.me"]

# Polymarket
AI_TRADER_POLYMARKET_ENABLED=true
AI_TRADER_POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
AI_TRADER_POLYMARKET_TIMEOUT_SECONDS=8
AI_TRADER_POLYMARKET_CACHE_SECONDS=120

# External AI / data providers
AI_TRADER_FRED_API_KEY=
AI_TRADER_OPENAI_API_KEY=
AI_TRADER_OPENAI_BASE_URL=https://api.openai.com/v1
AI_TRADER_OPENAI_DEFAULT_MODEL=gpt-5.4
AI_TRADER_OPENAI_AVAILABLE_MODELS=gpt-5.4,gpt-5,gpt-5-mini
AI_TRADER_OPENAI_OAUTH_CLIENT_ID=
AI_TRADER_OPENAI_OAUTH_CLIENT_SECRET=
AI_TRADER_OPENAI_OAUTH_AUTHORIZE_URL=https://auth.openai.com/authorize
AI_TRADER_OPENAI_OAUTH_TOKEN_URL=https://auth0.openai.com/oauth/token
AI_TRADER_OPENAI_OAUTH_USERINFO_URL=https://auth0.openai.com/userinfo
AI_TRADER_OPENAI_OAUTH_REVOKE_URL=https://auth0.openai.com/oauth/revoke
AI_TRADER_OPENAI_OAUTH_AUDIENCE=https://api.openai.com/v1
AI_TRADER_OPENAI_OAUTH_SCOPES=openid profile email offline_access
AI_TRADER_OLLAMA_URL=http://127.0.0.1:11434

# Alert delivery
AI_TRADER_ALERT_ENABLE_IN_APP=true
AI_TRADER_ALERT_ENABLE_TELEGRAM=false
AI_TRADER_ALERT_ENABLE_DISCORD=false
AI_TRADER_ALERT_IN_APP_MIN_SEVERITY=info
AI_TRADER_ALERT_TELEGRAM_MIN_SEVERITY=warning
AI_TRADER_ALERT_DISCORD_MIN_SEVERITY=info
AI_TRADER_ALERT_DEDUPE_WINDOW_MINUTES=240
AI_TRADER_ALERT_COOLDOWN_MINUTES=60
AI_TRADER_TELEGRAM_BOT_TOKEN=
AI_TRADER_TELEGRAM_CHAT_ID=
AI_TRADER_DISCORD_WEBHOOK_URL=

# Docker Compose staging / reverse proxy
# These variables are consumed by docker-compose.prod.yml and the frontend runtime-config generator.
AI_TRADER_SERVER_NAME=aitrader.sajaljain.me
AI_TRADER_PUBLIC_BASE_URL=https://aitrader.sajaljain.me
AI_TRADER_PUBLIC_HTTP_PORT=80
AI_TRADER_PUBLIC_HTTPS_PORT=443
AI_TRADER_RUNTIME_API_BASE=/api
AI_TRADER_RUNTIME_FRONTEND_URL=https://aitrader.sajaljain.me
AI_TRADER_RUNTIME_BACKEND_URL=https://aitrader.sajaljain.me
AI_TRADER_HEALTHCHECK_BASE_URL=
AI_TRADER_TLS_MOUNT_DIR=./deploy/certs
AI_TRADER_TLS_CERT_PATH=/etc/nginx/certs/live/aitrader.sajaljain.me/fullchain.pem
AI_TRADER_TLS_KEY_PATH=/etc/nginx/certs/live/aitrader.sajaljain.me/privkey.pem
